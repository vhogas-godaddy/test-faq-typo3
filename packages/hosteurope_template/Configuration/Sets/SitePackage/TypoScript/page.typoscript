    includeJS {

    }

    includeJSFooterlibs {

    }

    includeJSFooter {
        tags = https://tags.tiqcdn.com/utag/gpl/hosteurope/prod/utag.js
        tags.async = 1
        pm = https://sxb1pprd001.cloudstorage.secureserver.net/recomm-assets/privacy-manager-v4.0.js
        pm.async = 1
        pm.external = 1
        pmInit = EXT:hosteurope_template/Resources/Public/js/pm.js?v=1
        hosteurope_template_scripts = EXT:hosteurope_template/Resources/Public/js/h.js
    }
