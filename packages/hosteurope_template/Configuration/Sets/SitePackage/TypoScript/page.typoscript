##############
#### PAGE ####
##############
page = PAGE
page {
    typeNum = 0
    shortcutIcon = EXT:hosteurope_template/Resources/Public/icons/favicon.ico

    10 = PAGEVIEW
    10 {
        paths {
            0 = EXT:hosteurope_template/Resources/Private/PageView/
            1 = {$page.pageview.paths}
        }
        dataProcessing {
            10 = files
            10 {
                references.fieldName = media
            }
            20 = menu
            20 {
                levels = 2
                includeSpacer = 1
                as = mainnavigation
            }
            30 = page-content
        }
    }

    meta {
        viewport = {$page.meta.viewport}
        robots = {$page.meta.robots}
        apple-mobile-web-app-capable = {$page.meta.apple-mobile-web-app-capable}

        X-UA-Compatible = {$page.meta.compatible}
        X-UA-Compatible {
            attribute = http-equiv
        }
    }

    headTag {
        20 = TEXT
        20.value = <base href="/">
    }

    headTag.append = TEXT
    headTag.append.value = <base href="/">

    headerData {
        100 = COA
        100 {
            10 = TEXT
            10 {
                data = path:EXT:hosteurope_template/Resources/Public/icons/favicon.ico
                wrap = <link rel="shortcut icon" type="image/x-icon" href="|">
            }
            20 = TEXT
            20 {
                data = path:EXT:hosteurope_template/Resources/Public/icons/favicon.ico
                wrap = <link rel="icon" type="image/x-icon" href="|">
            }
            30 = TEXT
            30 {
                data = path:EXT:hosteurope_template/Resources/Public/icons/favicon.gif
                wrap = <link rel="icon" type="image/gif" href="|">
            }
            40 = TEXT
            40 {
                data = path:EXT:hosteurope_template/Resources/Public/icons/favicon.png
                wrap = <link rel="icon" type="image/png" href="|">
            }
            50 = TEXT
