RewriteRule ^(.*)$ https://www.hosteurope.de/racer/ [R=301,L]


RewriteCond %{HTTP_HOST} ^(www\.)?goracer\.de$ [NC]
RewriteRule ^(.*)$ https://www.hosteurope.de/racer/ [R=301,L]

